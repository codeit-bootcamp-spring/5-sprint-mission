# Discodeit Environment Variables
# Copy this file to .env and fill in the values

# =============================================================================
# PROFILE
# =============================================================================

SPRING_PROFILES_ACTIVE=local

# =============================================================================
# REQUIRED
# =============================================================================

# JWT Authentication (REQUIRED - application will not start without these)
JWT_ACCESS_SECRET=your-access-token-secret-key-min-32-characters
JWT_REFRESH_SECRET=your-refresh-token-secret-key-min-32-characters

# =============================================================================
# DATABASE
# =============================================================================

SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/discodeit
SPRING_DATASOURCE_USERNAME=discodeit
SPRING_DATASOURCE_PASSWORD=discodeit

# =============================================================================
# CACHING
# =============================================================================

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
SPRING_CACHE_TYPE=redis

# =============================================================================
# MESSAGING
# =============================================================================

# Kafka Configuration
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_CONSUMER_GROUP=discodeit-group

# =============================================================================
# STORAGE
# =============================================================================

# Storage Type: local or s3
STORAGE_TYPE=local
STORAGE_LOCAL_ROOT_PATH=.discodeit/storage
STORAGE_ORPHAN_GRACE=1h

# AWS S3 Configuration (required if STORAGE_TYPE=s3)
# AWS_S3_ACCESS_KEY=
# AWS_S3_SECRET_KEY=
# AWS_S3_REGION=ap-northeast-2
# AWS_S3_BUCKET=discodeit-bucket
# AWS_S3_PRESIGNED_URL_EXPIRATION=10m

# =============================================================================
# JWT (OPTIONAL - defaults provided)
# =============================================================================

# JWT_ACCESS_SECRET_PREVIOUS=         # For graceful secret rotation
# JWT_ACCESS_EXPIRATION=1800000       # 30 minutes (in milliseconds)
# JWT_REFRESH_SECRET_PREVIOUS=        # For graceful secret rotation
# JWT_REFRESH_EXPIRATION=604800000    # 7 days (in milliseconds)
# JWT_MAX_SESSIONS=1                  # Max concurrent sessions per user

# =============================================================================
# RATE LIMITING
# =============================================================================

# RATE_LIMIT_MAX_ATTEMPTS=5           # Max login attempts
# RATE_LIMIT_WINDOW_SECONDS=60        # Time window for attempts
# RATE_LIMIT_BLOCK_SECONDS=300        # Block duration (5 minutes)

# =============================================================================
# ADMIN USER
# =============================================================================

# Enable admin user initialization on startup
# DISCODEIT_ADMIN_ENABLED=false
# DISCODEIT_ADMIN_USERNAME=admin
# DISCODEIT_ADMIN_EMAIL=admin@discodeit.com
# DISCODEIT_ADMIN_PASSWORD=

# =============================================================================
# API
# =============================================================================

# API_SERVER_URL=http://localhost:8080
# API_VERSION=2.2-M11

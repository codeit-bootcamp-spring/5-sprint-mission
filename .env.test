SPRING_PROFILES_ACTIVE=test

SPRING_DATASOURCE_URL=jdbc:h2:mem:discodeit-test;MODE=PostgreSQL;DB_CLOSE_DELAY=-1;DB_CLOSE_ON_EXIT=FALSE
SPRING_DATASOURCE_DRIVER_CLASS_NAME=org.h2.Driver
SPRING_DATASOURCE_USERNAME=sa
SPRING_DATASOURCE_PASSWORD=

SPRING_CACHE_TYPE=in-memory

REDIS_HOST=localhost
REDIS_PORT=6379

KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_CONSUMER_GROUP=discodeit-group

ADMIN_ENABLED=true
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@test.com
ADMIN_PASSWORD=admin-test-password

API_SERVER_URL=http://localhost:8080
API_VERSION=2.2-M11

ASYNC_CORE_POOL_SIZE=10
ASYNC_MAX_POOL_SIZE=50
ASYNC_QUEUE_CAPACITY=100
ASYNC_AWAIT_TERMINATION_SECONDS=30

DATASOURCE_PROXY_ENABLED=true

JWT_ACCESS_SECRET=test-access-secret-key-must-be-at-least-32-characters
# JWT_ACCESS_SECRET_PREVIOUS
# JWT_ACCESS_EXPIRATION=30m
JWT_REFRESH_SECRET=test-refresh-secret-key-must-be-at-least-32-characters
# JWT_REFRESH_SECRET_PREVIOUS
# JWT_REFRESH_EXPIRATION=7d
JWT_REFRESH_TOKEN_COOKIE_NAME=DISCODEIT_REFRESH_TOKEN
JWT_MAX_SESSIONS=2
JWT_REGISTRY_TYPE=in-memory

# RATE_LIMIT_MAX_ATTEMPTS=5
# RATE_LIMIT_WINDOW_DURATION=10s
# RATE_LIMIT_BLOCK_DURATION=1m
RATE_LIMIT_REGISTRY_TYPE=in-memory

# AWS_S3_ACCESS_KEY=test-access-key
# AWS_S3_SECRET_KEY=test-secret-key
# AWS_S3_REGION=ap-northeast-2
# AWS_S3_BUCKET=test-bucket
# AWS_S3_PRESIGNED_URL_EXPIRATION=10m

STORAGE_ORPHAN_GRACE=1s
STORAGE_CLEANUP_INTERVAL=3600000
